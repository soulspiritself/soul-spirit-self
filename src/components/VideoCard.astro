---
interface Props {
  youtubeId: string;
  title: string;
  caption?: string;
}
const { youtubeId, title, caption } = Astro.props;
const thumb = `https://img.youtube.com/vi/${youtubeId}/hqdefault.jpg`;
const url = `https://youtu.be/${youtubeId}`;
---
<a href={url} target="_blank" rel="noopener" class="video-card" aria-label={title}>
  <div class="thumb-wrap">
    <img src={thumb} alt={title} loading="lazy" />
    <span class="play-icon" aria-hidden="true">
      <svg viewBox="0 0 32 32" width="56" height="56">
        <circle cx="16" cy="16" r="15" fill="rgba(201, 169, 110, 0.92)" />
        <path d="M13 11 L22 16 L13 21 Z" fill="#1a4a65" />
      </svg>
    </span>
  </div>
  <div class="video-meta">
    <p class="video-title">{title}</p>
    {caption && <p class="video-caption">{caption}</p>}
  </div>
</a>

<style>
  .video-card {
    color: inherit;
    display: block;
    transition: transform 0.3s ease;
  }
  .video-card:hover {
    color: inherit;
    transform: translateY(-3px);
  }
  .thumb-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--line);
    background: var(--bg-panel);
  }
  .thumb-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .video-card:hover .thumb-wrap img {
    transform: scale(1.04);
  }
  .play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.4));
  }
  .video-meta {
    margin-top: 14px;
  }
  .video-title {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--text);
    line-height: 1.5;
  }
  .video-caption {
    font-size: 12px;
    color: var(--text-faint);
    margin-top: 4px;
  }
</style>
