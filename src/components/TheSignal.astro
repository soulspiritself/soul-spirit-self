---
import { getCollection } from 'astro:content';
import { signalStories, categoryLabel } from '../data/signal';

// Merge hosted (republished) + external (linkout) into one feed, newest first.
const hosted = (await getCollection('signal')).map(s => ({
  category: s.data.category,
  headline: s.data.headline,
  note: s.data.note,
  source: s.data.source,
  readTime: s.data.readTime,
  date: s.data.date,
  image: s.data.image,
  url: `/signal/${s.slug}/`,
  hosted: true as const,
}));
const hostedSourceUrls = new Set((await getCollection('signal')).map(s => s.data.sourceUrl));
const external = signalStories
  .filter(s => !hostedSourceUrls.has(s.url))
  .map(s => ({ ...s, hosted: false as const }));

const allStories = [...hosted, ...external].sort((a, b) => b.date.localeCompare(a.date));
const featured = allStories[0];
const rest = allStories.slice(1, 4);
---

<section class="section signal-section">
  <div class="signal-header">
    <div>
      <span class="eyebrow">The Signal</span>
      <h2>What's worth reading</h2>
      <p class="signal-lede">
        Stories from consciousness research, contemplative practice, and the wisdom traditions, curated as they surface.
      </p>
    </div>
    <a href="/signal/" class="signal-all">All stories →</a>
  </div>

  <!-- Featured story -->
  <a
    href={featured.url}
    target={featured.hosted ? '_self' : '_blank'}
    rel={featured.hosted ? null : 'noopener'}
    class={`signal-featured ${featured.image ? 'with-image' : ''}`}
  >
    {featured.image && (
      <div class="signal-featured-image">
        <img src={featured.image} alt={featured.headline} loading="eager" />
      </div>
    )}
    <div class="signal-featured-inner">
      <span class={`signal-cat signal-cat--${featured.category}`}>
        {categoryLabel[featured.category]}
      </span>
      {featured.hosted && <span class="hosted-tag">Read here</span>}
      <h3 class="signal-featured-hed">{featured.headline}</h3>
      <p class="signal-featured-note">{featured.note}</p>
      <p class="signal-meta">
        <span class="signal-source">{featured.source}</span>
        <span class="signal-dot" aria-hidden="true">·</span>
        <span class="signal-time">{featured.readTime} min read</span>
      </p>
    </div>
    <div class="signal-featured-icon" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M3 12h1M20 12h1M12 3v1M12 20v1M5.6 5.6l.7.7M17.7 17.7l.7.7M17.7 6.3l-.7.7M6.3 17.7l-.7.7"/>
        <circle cx="12" cy="12" r="8" stroke-dasharray="2 3"/>
      </svg>
    </div>
  </a>

  <!-- Supporting stories -->
  <div class="signal-grid">
    {rest.map(story => (
      <a
        href={story.url}
        target={story.hosted ? '_self' : '_blank'}
        rel={story.hosted ? null : 'noopener'}
        class="signal-card"
      >
        <div class={`signal-card-image cat--${story.category}`}>
          {story.image
            ? <img src={story.image} alt={story.headline} loading="lazy" />
            : <svg class="signal-card-image-glyph" viewBox="0 0 64 64" aria-hidden="true">
                <circle cx="32" cy="32" r="14" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.55"/>
                <circle cx="32" cy="32" r="22" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.30"/>
                <circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="0.4" opacity="0.15"/>
                <circle cx="32" cy="32" r="3" fill="currentColor" opacity="0.75"/>
              </svg>}
        </div>
        <span class={`signal-cat signal-cat--${story.category}`}>
          {categoryLabel[story.category]}
        </span>
        {story.hosted && <span class="hosted-tag">Read here</span>}
        <h4 class="signal-card-hed">{story.headline}</h4>
        <p class="signal-card-note">{story.note}</p>
        <p class="signal-meta">
          <span class="signal-source">{story.source}</span>
          <span class="signal-dot" aria-hidden="true">·</span>
          <span class="signal-time">{story.readTime} min</span>
        </p>
      </a>
    ))}
  </div>
</section>

<style>
  .signal-section {
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .signal-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .signal-header h2 {
    font-family: var(--serif);
    font-size: 44px;
    font-weight: 400;
    margin-top: 12px;
    letter-spacing: 0.01em;
  }

  .signal-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--text-muted);
    margin-top: 10px;
    line-height: 1.6;
    max-width: 520px;
  }

  .signal-all {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  /* Category pills */
  .signal-cat {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 14px;
  }
  .signal-cat--consciousness {
    background: rgba(100, 80, 200, 0.18);
    color: #c4b8f0;
    border: 1px solid rgba(150, 120, 220, 0.25);
  }
  .signal-cat--meditation {
    background: rgba(30, 130, 100, 0.18);
    color: #8ddec4;
    border: 1px solid rgba(50, 160, 120, 0.25);
  }
  .signal-cat--wisdom {
    background: rgba(180, 130, 50, 0.18);
    color: #d4a95a;
    border: 1px solid rgba(200, 155, 70, 0.25);
  }
  .hosted-tag {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 3px 9px;
    margin-bottom: 14px;
    margin-left: 6px;
    border-radius: 20px;
    background: rgba(201, 169, 110, 0.14);
    color: var(--accent);
    border: 1px solid rgba(201, 169, 110, 0.4);
  }

  /* Featured */
  .signal-featured {
    display: grid;
    grid-template-columns: 1fr 64px;
    gap: 24px;
    align-items: start;
    padding: 32px 36px;
    border: 1px solid var(--line-strong);
    border-radius: 6px;
    background: rgba(10, 30, 45, 0.38);
    margin-bottom: 20px;
    transition: border-color 0.25s, background 0.25s;
    color: inherit;
  }
  .signal-featured.with-image {
    grid-template-columns: 260px 1fr;
    padding: 0;
    overflow: hidden;
    gap: 0;
  }
  .signal-featured.with-image .signal-featured-inner {
    padding: 28px 32px;
    align-self: center;
  }
  .signal-featured-image {
    align-self: stretch;
    background: var(--bg-soft);
    overflow: hidden;
    min-height: 200px;
  }
  .signal-featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .signal-featured.with-image:hover .signal-featured-image img { transform: scale(1.03); }
  .signal-featured:hover {
    border-color: var(--accent-deep);
    background: rgba(10, 30, 45, 0.55);
    color: inherit;
  }

  .signal-featured-hed {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--text);
    margin-bottom: 14px;
    letter-spacing: 0.01em;
  }

  .signal-featured-note {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 18px;
  }

  .signal-featured-icon {
    color: var(--accent-deep);
    padding-top: 6px;
    display: flex;
    justify-content: flex-end;
  }

  /* Meta */
  .signal-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }
  .signal-dot { opacity: 0.4; }

  /* Card grid */
  .signal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .signal-card {
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: rgba(10, 30, 45, 0.28);
    transition: border-color 0.25s, background 0.25s;
    color: inherit;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .signal-card-image {
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--line);
  }
  .signal-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .signal-card:hover .signal-card-image img { transform: scale(1.03); }
  .signal-card-image.cat--consciousness:not(:has(img)) {
    background: linear-gradient(135deg, rgba(100,80,200,0.35) 0%, rgba(40,30,80,0.55) 100%);
  }
  .signal-card-image.cat--meditation:not(:has(img)) {
    background: linear-gradient(135deg, rgba(30,130,100,0.35) 0%, rgba(15,55,40,0.55) 100%);
  }
  .signal-card-image.cat--wisdom:not(:has(img)) {
    background: linear-gradient(135deg, rgba(180,130,50,0.35) 0%, rgba(70,50,20,0.55) 100%);
  }
  .signal-card-image-glyph {
    width: 64px;
    height: 64px;
    color: rgba(255, 255, 255, 0.85);
  }
  .signal-card-image.cat--consciousness .signal-card-image-glyph { color: #c4b8f0; }
  .signal-card-image.cat--meditation    .signal-card-image-glyph { color: #8ddec4; }
  .signal-card-image.cat--wisdom        .signal-card-image-glyph { color: var(--accent); }
  .signal-card > .signal-cat,
  .signal-card > .hosted-tag,
  .signal-card > .signal-card-hed,
  .signal-card > .signal-card-note,
  .signal-card > .signal-meta {
    margin-left: 22px;
    margin-right: 22px;
  }
  .signal-card > .signal-cat { margin-top: 18px; }
  .signal-card > .signal-meta { margin-bottom: 20px; }
  .signal-card:hover {
    border-color: var(--line-strong);
    background: rgba(10, 30, 45, 0.45);
    color: inherit;
  }

  .signal-card-hed {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 10px;
    letter-spacing: 0.01em;
  }

  .signal-card-note {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  @media (max-width: 900px) {
    .signal-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .signal-featured { grid-template-columns: 1fr; }
    .signal-featured.with-image { grid-template-columns: 1fr; }
    .signal-featured-image { min-height: 0; max-height: 180px; }
    .signal-featured.with-image .signal-featured-inner { padding: 22px 20px; }
    .signal-featured-icon { display: none; }
    .signal-grid { grid-template-columns: 1fr; }
    .signal-header h2 { font-size: 34px; }
  }
</style>
