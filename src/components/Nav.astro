---
const path = Astro.url.pathname;
const links = [
  { href: '/traditions/', label: 'Traditions' },
  { href: '/teachers/', label: 'Teachers' },
  { href: '/texts/', label: 'Texts' },
  { href: '/themes/', label: 'Themes' },
  { href: '/watch/', label: 'Watch' },
  { href: '/reading/', label: 'Reading' },
  { href: '/about/', label: 'About' },
];
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <img src="/images/soul-spirit-self-logo.png" alt="Soul Spirit Self" class="brand-logo" />
      <span class="brand-text">Soul Spirit Self</span>
    </a>
    <div class="nav-links">
      {links.map(link => (
        <a href={link.href} class={path.startsWith(link.href) ? 'current' : ''}>{link.label}</a>
      ))}
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(20, 58, 82, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 14px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--text);
  }
  .brand:hover { color: var(--text); }
  .brand-logo {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .brand-text {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text);
  }
  .nav-links {
    display: flex;
    gap: 36px;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 400;
  }
  .nav-links a { color: var(--text-muted); }
  .nav-links a:hover, .nav-links a.current { color: var(--accent); }
  @media (max-width: 700px) {
    .nav-links { display: none; }
    .brand-text { font-size: 15px; letter-spacing: 0.12em; }
  }
</style>
