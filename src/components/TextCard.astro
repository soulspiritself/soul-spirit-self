---
interface Props {
  href: string;
  title: string;
  originalTitle?: string;
  meta: string;
  description: string;
  image?: string;
  imagePrompt?: string;
}
const { href, title, originalTitle, meta, description, image, imagePrompt } = Astro.props;
---
<a href={href} class="text-card">
  <div class="text-card-image">
    {image
      ? <img src={image} alt={imagePrompt || title} />
      : <div class="imagen-placeholder"></div>}
    <span class="text-card-image-tag">{image ? 'Imagen 4' : 'Image pending'}</span>
  </div>
  <div class="text-card-body">
    <span class="text-card-meta">{meta}</span>
    <h3 class="text-card-title">{title}</h3>
    {originalTitle && <p class="text-card-original">{originalTitle}</p>}
    <p class="text-card-desc">{description}</p>
    <span class="text-card-link">Read text</span>
  </div>
</a>

<style>
  .text-card {
    display: flex; flex-direction: column;
    background: transparent;
    border: 1px solid var(--line);
    transition: border-color 0.3s, transform 0.3s;
    color: inherit;
  }
  .text-card:hover { border-color: var(--accent-deep); transform: translateY(-2px); color: inherit; }
  .text-card-image {
    position: relative;
    aspect-ratio: 4/3;
    background: var(--bg-soft);
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .text-card-image img { width: 100%; height: 100%; object-fit: cover; }
  .text-card-image-tag {
    position: absolute; bottom: 12px; right: 12px;
    padding: 4px 10px;
    background: rgba(10, 14, 26, 0.7);
    border: 1px solid var(--line-strong);
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-faint);
  }
  .text-card-body { padding: 28px 28px 32px; flex: 1; display: flex; flex-direction: column; }
  .text-card-meta { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); font-weight: 500; margin-bottom: 14px; }
  .text-card-title { font-family: var(--serif); font-size: 30px; font-weight: 500; line-height: 1.15; color: var(--text); margin-bottom: 8px; }
  .text-card-original { font-family: var(--serif); font-size: 16px; font-style: italic; color: var(--text-faint); margin-bottom: 18px; letter-spacing: 0.02em; }
  .text-card-desc { font-size: 15px; line-height: 1.65; color: var(--text-muted); font-weight: 300; flex: 1; margin-bottom: 22px; }
  .text-card-link { font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); font-weight: 500; display: inline-flex; align-items: center; gap: 10px; }
  .text-card-link::after { content: '\2192'; transition: transform 0.3s; }
  .text-card:hover .text-card-link::after { transform: translateX(4px); }
</style>
