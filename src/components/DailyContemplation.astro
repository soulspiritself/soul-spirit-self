---
import { contemplations, todaysContemplation } from '../data/contemplations';

// Server-rendered initial quote (today's, picked by day-of-year).
// Then a client script re-picks on page load against the visitor's local date,
// so the card always shows today's quote even if the site hasn't been rebuilt.
const initial = todaysContemplation();
---
<section class="contemplation-wrap">
  <div class="contemplation">
    <div class="stars" aria-hidden="true"></div>
    <span class="eyebrow">Daily contemplation</span>
    <blockquote>
      <p data-quote>{initial.quote}</p>
    </blockquote>
    <div class="rule-gold-h"></div>
    <p class="attribution" data-author>{initial.author}</p>
    <p class="source" data-source>{initial.source ?? ''}</p>
  </div>
</section>

<script is:inline define:vars={{ contemplations }}>
  (function () {
    const now = new Date();
    const start = new Date(now.getFullYear(), 0, 0);
    const dayOfYear = Math.floor((now - start) / 86400000);
    const c = contemplations[dayOfYear % contemplations.length];

    const quoteEl = document.querySelector('[data-quote]');
    const authorEl = document.querySelector('[data-author]');
    const sourceEl = document.querySelector('[data-source]');

    if (quoteEl) quoteEl.textContent = c.quote;
    if (authorEl) authorEl.textContent = c.author;
    if (sourceEl) {
      sourceEl.textContent = c.source || '';
      sourceEl.style.display = c.source ? '' : 'none';
    }
  })();
</script>

<style>
  .contemplation-wrap {
    padding: 64px var(--gutter);
    display: flex;
    justify-content: center;
  }
  .contemplation {
    position: relative;
    max-width: 640px;
    width: 100%;
    padding: 64px 48px;
    background:
      radial-gradient(ellipse at 30% 30%, rgba(50, 120, 160, 0.4) 0%, rgba(20, 58, 82, 0.55) 60%, transparent 100%);
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    text-align: center;
  }
  .stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(2px 2px at 12% 18%, rgba(255, 255, 255, 0.55), transparent),
      radial-gradient(1.5px 1.5px at 22% 72%, rgba(255, 255, 255, 0.4), transparent),
      radial-gradient(1px 1px at 38% 38%, rgba(255, 255, 255, 0.6), transparent),
      radial-gradient(1.8px 1.8px at 52% 22%, rgba(201, 169, 110, 0.6), transparent),
      radial-gradient(1px 1px at 64% 80%, rgba(255, 255, 255, 0.5), transparent),
      radial-gradient(1.5px 1.5px at 78% 32%, rgba(255, 255, 255, 0.4), transparent),
      radial-gradient(1px 1px at 88% 64%, rgba(201, 169, 110, 0.55), transparent),
      radial-gradient(1.2px 1.2px at 8% 56%, rgba(255, 255, 255, 0.45), transparent),
      radial-gradient(1.5px 1.5px at 70% 12%, rgba(255, 255, 255, 0.5), transparent);
    pointer-events: none;
    opacity: 0.85;
  }
  .contemplation .eyebrow {
    position: relative;
    display: block;
    margin-bottom: 28px;
  }
  blockquote {
    position: relative;
    margin: 0;
  }
  blockquote p {
    font-family: var(--serif);
    font-size: 28px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.45;
    color: var(--text);
    letter-spacing: 0.01em;
  }
  .attribution {
    position: relative;
    font-size: 12px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    margin-top: 4px;
  }
  .source {
    position: relative;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-top: 6px;
  }
  @media (max-width: 600px) {
    .contemplation { padding: 44px 28px; }
    blockquote p { font-size: 22px; }
  }
</style>
