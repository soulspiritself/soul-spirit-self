---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const traditions = (await getCollection('traditions')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Traditions" description="Seven contemplative traditions, one nondual recognition.">

  <section class="page-hero">
    <div class="wrapper">
      <span class="eyebrow">The library</span>
      <h1>Traditions</h1>
      <p>Each tradition is a distinct articulation of one recognition. Different vocabulary, different rituals, different lineages, the same pointing.</p>
    </div>
  </section>

  <section class="section">
    <div class="trads-list">
      {traditions.map(t => (
        <a href={`/traditions/${t.slug}/`} class="trad-row">
          <div class="trad-row-text">
            <h2>{t.data.title}</h2>
            <p>{t.data.subtitle}</p>
          </div>
          <span class="trad-row-link">Enter →</span>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero { padding: 80px var(--gutter) 64px; max-width: var(--max-width); margin: 0 auto; }
  .page-hero h1 { font-size: 72px; font-weight: 400; letter-spacing: -0.02em; margin: 20px 0 24px; }
  .page-hero p { font-family: var(--serif); font-size: 22px; font-style: italic; color: var(--text-muted); max-width: 640px; }
  .trads-list { display: flex; flex-direction: column; }
  .trad-row { display: flex; justify-content: space-between; align-items: center; padding: 36px 0; border-top: 1px solid var(--line); transition: all 0.3s; color: inherit; }
  .trad-row:last-child { border-bottom: 1px solid var(--line); }
  .trad-row:hover { padding-left: 12px; color: inherit; }
  .trad-row-text h2 { font-family: var(--serif); font-size: 36px; font-weight: 400; color: var(--text); margin-bottom: 6px; }
  .trad-row-text p { font-size: 16px; color: var(--text-muted); }
  .trad-row-link { font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); font-weight: 500; white-space: nowrap; margin-left: 24px; }
</style>
