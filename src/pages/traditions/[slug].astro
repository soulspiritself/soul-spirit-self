---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TextCard from '../../components/TextCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const traditions = await getCollection('traditions');
  return traditions.map(tradition => ({
    params: { slug: tradition.slug },
    props: { tradition },
  }));
}

const { tradition } = Astro.props;
const { Content } = await tradition.render();

const allTexts = await getCollection('texts');
const texts = allTexts
  .filter(t => t.data.tradition.slug === tradition.slug)
  .sort((a, b) => a.data.order - b.data.order);

const allTeachers = await getCollection('teachers');
const teachers = allTeachers.filter(t => t.data.tradition.slug === tradition.slug);
---
<BaseLayout title={tradition.data.title} description={tradition.data.description} image={tradition.data.image}>

  <section class="trad-hero">
    <div class="trad-hero-bg" style={tradition.data.image ? `background-image: url(${tradition.data.image});` : ''}></div>
    {!tradition.data.image && import.meta.env.DEV && (
      <span class="hero-imagen-tag">Imagen 4 hero · pending generation</span>
    )}
    <div class="trad-hero-content">
      <span class="eyebrow">{tradition.data.eyebrow}</span>
      <h1>{tradition.data.title}</h1>
      <p>{tradition.data.subtitle}</p>
    </div>
  </section>

  <section class="section">
    <div class="trad-overview">
      <Content />
    </div>
  </section>

  {texts.length > 0 && (
    <section class="section" style="padding-top: 0;">
      <div class="section-header">
        <span class="eyebrow">Foundational and classical texts</span>
        <h2>The library</h2>
      </div>
      <div class="texts-grid">
        {texts.map(text => (
          <TextCard
            href={`/texts/${text.slug}/`}
            title={text.data.title}
            originalTitle={text.data.originalTitle}
            meta={text.data.period || ''}
            description={text.data.description}
            image={text.data.image}
            imagePrompt={text.data.imagePrompt}
          />
        ))}
      </div>
    </section>
  )}

  {teachers.length > 0 && (
    <section class="section" style="padding-top: 0;">
      <div class="section-header">
        <span class="eyebrow">Teachers in this lineage</span>
        <h2>The voices</h2>
      </div>
      <div class="teachers-grid">
        {teachers.map(teacher => (
          <a href={`/teachers/${teacher.slug}/`} class="teacher-card">
            <div class="teacher-portrait" data-initial={teacher.data.name.charAt(0)}>
              {teacher.data.image && <img src={teacher.data.image} alt={teacher.data.name} />}
            </div>
            <div class="teacher-name">{teacher.data.name}</div>
            <div class="teacher-dates">
              {teacher.data.born && teacher.data.died ? `${teacher.data.born} — ${teacher.data.died}` : (teacher.data.born || teacher.data.died || '')}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .trad-hero { position: relative; min-height: 520px; display: flex; align-items: flex-end; padding: 0; overflow: hidden; border-bottom: 1px solid var(--line); }
  .trad-hero-bg { position: absolute; inset: 0; background-color: var(--bg-soft); background-size: cover; background-position: center; background-repeat: no-repeat; }
  .trad-hero-bg::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 40%, rgba(201,169,97,0.18) 0%, transparent 55%), radial-gradient(ellipse at 70% 60%, rgba(80,60,140,0.22) 0%, transparent 60%), linear-gradient(180deg, rgba(10,14,26,0.4) 0%, rgba(10,14,26,0.85) 100%); }
  .hero-imagen-tag { position: absolute; top: 24px; right: var(--gutter); padding: 6px 14px; background: rgba(10,14,26,0.6); border: 1px solid var(--line-strong); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-faint); z-index: 2; }
  .trad-hero-content { position: relative; z-index: 1; max-width: var(--max-width); width: 100%; margin: 0 auto; padding: 80px var(--gutter) 64px; }
  .trad-hero h1 { font-size: 84px; font-weight: 400; line-height: 1; letter-spacing: -0.02em; margin: 24px 0 24px; }
  .trad-hero p { font-family: var(--serif); font-size: 24px; font-weight: 300; font-style: italic; color: var(--text-muted); max-width: 680px; line-height: 1.4; }

  .section-header { margin-bottom: 64px; max-width: 820px; }
  .section-header h2 { font-size: 48px; font-weight: 400; margin-top: 20px; letter-spacing: -0.01em; }

  .trad-overview { max-width: 820px; font-family: var(--serif); font-size: 21px; font-weight: 300; line-height: 1.6; color: var(--text-muted); }
  .trad-overview :global(p + p) { margin-top: 20px; }
  .trad-overview :global(a) { color: var(--accent); text-decoration: none; border-bottom: 1px solid rgba(201,169,97,0.4); transition: border-color 0.25s ease, color 0.25s ease; }
  .trad-overview :global(a:hover) { color: var(--text); border-bottom-color: var(--accent); }

  .texts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 40px 32px; }

  .teachers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 32px; }
  .teacher-card { text-align: center; color: inherit; display: block; }
  .teacher-portrait { width: 160px; height: 160px; border-radius: 50%; background: var(--bg-soft); margin: 0 auto 18px; border: 1px solid var(--line); position: relative; overflow: hidden; transition: border-color 0.3s; }
  .teacher-card:hover .teacher-portrait { border-color: var(--accent-deep); }
  .teacher-portrait img { width: 100%; height: 100%; object-fit: cover; }
  .teacher-portrait::after { content: attr(data-initial); position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 64px; font-weight: 300; color: var(--text-faint); }
  .teacher-portrait:has(img)::after { display: none; }
  .teacher-name { font-family: var(--serif); font-size: 22px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
  .teacher-dates { font-size: 12px; letter-spacing: 0.06em; color: var(--text-faint); }

  @media (max-width: 700px) { .trad-hero h1 { font-size: 56px; } }
</style>
