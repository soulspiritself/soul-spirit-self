---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { signalStories, categoryLabel } from '../../data/signal';

// Hosted (republished CC-BY / CC-BY-ND) stories live in the `signal` content
// collection. Card links go to /signal/<slug>/ instead of the source URL.
const hosted = (await getCollection('signal')).map(s => ({
  category: s.data.category,
  headline: s.data.headline,
  note: s.data.note,
  source: s.data.source,
  readTime: s.data.readTime,
  date: s.data.date,
  image: s.data.image,
  // Internal link to the on-site page (note trailing slash for our build format)
  url: `/signal/${s.slug}/`,
  hosted: true as const,
}));

// External (linkout-only) stories come from data/signal.ts. Skip any whose
// canonical sourceUrl matches a hosted one so we don't double-list.
const hostedSourceUrls = new Set((await getCollection('signal')).map(s => s.data.sourceUrl));
const external = signalStories
  .filter(s => !hostedSourceUrls.has(s.url))
  .map(s => ({ ...s, image: undefined as string | undefined, hosted: false as const }));

const stories = [...hosted, ...external].sort((a, b) => b.date.localeCompare(a.date));
const featured = stories[0];
const rest = stories.slice(1);

const categories: Array<{ key: 'all' | 'consciousness' | 'meditation' | 'wisdom'; label: string }> = [
  { key: 'all',           label: 'All' },
  { key: 'consciousness', label: 'Consciousness & science' },
  { key: 'meditation',    label: 'Meditation' },
  { key: 'wisdom',        label: 'Wisdom traditions' },
];

function formatDate(iso: string) {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---
<BaseLayout
  title="The Signal"
  description="Stories from consciousness research, contemplative practice, and the wisdom traditions, curated as they surface."
>
  <section class="signal-hero">
    <span class="eyebrow">The Signal</span>
    <h1>What&rsquo;s worth reading</h1>
    <p class="lede">
      Stories from consciousness research, contemplative practice, and the wisdom traditions, curated as they surface.
    </p>
    <div class="rule-gold-h"></div>
  </section>

  <section class="signal-filters">
    <div class="filter-row" role="tablist" aria-label="Filter stories by category">
      {categories.map(c => (
        <button
          class={`filter-pill${c.key === 'all' ? ' active' : ''}`}
          data-cat={c.key}
          role="tab"
          aria-selected={c.key === 'all' ? 'true' : 'false'}
        >
          {c.label}
        </button>
      ))}
    </div>
  </section>

  <section class="signal-list">
    <a
      href={featured.url}
      target={featured.hosted ? '_self' : '_blank'}
      rel={featured.hosted ? null : 'noopener'}
      class={`signal-featured story ${featured.image ? 'with-image' : ''}`}
      data-cat={featured.category}
    >
      {featured.image && (
        <div class="signal-featured-image">
          <img src={featured.image} alt={featured.headline} loading="eager" />
        </div>
      )}
      <div class="signal-featured-inner">
        <span class={`signal-cat signal-cat--${featured.category}`}>
          {categoryLabel[featured.category]}
        </span>
        {featured.hosted && <span class="hosted-tag">Read here</span>}
        <h2 class="signal-featured-hed">{featured.headline}</h2>
        <p class="signal-featured-note">{featured.note}</p>
        <p class="signal-meta">
          <span class="signal-source">{featured.source}</span>
          <span class="signal-dot" aria-hidden="true">·</span>
          <span class="signal-time">{featured.readTime} min read</span>
          <span class="signal-dot" aria-hidden="true">·</span>
          <span class="signal-date">{formatDate(featured.date)}</span>
        </p>
      </div>
      <div class="signal-featured-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/>
          <path d="M3 12h1M20 12h1M12 3v1M12 20v1M5.6 5.6l.7.7M17.7 17.7l.7.7M17.7 6.3l-.7.7M6.3 17.7l-.7.7"/>
          <circle cx="12" cy="12" r="8" stroke-dasharray="2 3"/>
        </svg>
      </div>
    </a>

    <div class="signal-grid">
      {rest.map(story => (
        <a
          href={story.url}
          target={story.hosted ? '_self' : '_blank'}
          rel={story.hosted ? null : 'noopener'}
          class="signal-card story"
          data-cat={story.category}
        >
          <div class={`signal-card-image cat--${story.category}`}>
            {story.image
              ? <img src={story.image} alt={story.headline} loading="lazy" />
              : <span class="signal-card-image-placeholder" aria-hidden="true">{story.source.charAt(0)}</span>}
          </div>
          <span class={`signal-cat signal-cat--${story.category}`}>
            {categoryLabel[story.category]}
          </span>
          {story.hosted && <span class="hosted-tag">Read here</span>}
          <h3 class="signal-card-hed">{story.headline}</h3>
          <p class="signal-card-note">{story.note}</p>
          <p class="signal-meta">
            <span class="signal-source">{story.source}</span>
            <span class="signal-dot" aria-hidden="true">·</span>
            <span class="signal-time">{story.readTime} min</span>
            <span class="signal-dot" aria-hidden="true">·</span>
            <span class="signal-date">{formatDate(story.date)}</span>
          </p>
        </a>
      ))}
    </div>

    <p class="signal-empty" id="signalEmpty" hidden>No stories in this category yet.</p>

    <p class="signal-rss">
      <a href="/signal/rss.xml" aria-label="The Signal RSS feed">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.5 21a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5zM3 10v3a8 8 0 0 1 8 8h3A11 11 0 0 0 3 10zm0-7v3a15 15 0 0 1 15 15h3A18 18 0 0 0 3 3z"/></svg>
        Subscribe by RSS
      </a>
    </p>
  </section>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const stories = document.querySelectorAll<HTMLElement>('.story');
  const empty = document.getElementById('signalEmpty');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const cat = pill.dataset.cat || 'all';
      pills.forEach(p => {
        const on = p === pill;
        p.classList.toggle('active', on);
        p.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      let visible = 0;
      stories.forEach(s => {
        const show = cat === 'all' || s.dataset.cat === cat;
        s.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (empty) empty.hidden = visible !== 0;
    });
  });
</script>

<style>
  .signal-hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px var(--gutter) 24px;
    text-align: center;
  }
  .signal-hero h1 {
    font-family: var(--serif);
    font-size: 56px;
    font-weight: 300;
    letter-spacing: 0.06em;
    margin-top: 16px;
  }
  .signal-hero .lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--text-muted);
    margin-top: 14px;
    max-width: 620px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .signal-filters {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px var(--gutter) 32px;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  .filter-pill {
    background: transparent;
    border: 1px solid rgba(201, 169, 110, 0.35);
    color: var(--text-muted);
    padding: 8px 18px;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    border-radius: 999px;
    font-weight: 400;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .filter-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .filter-pill.active {
    background: rgba(201, 169, 110, 0.10);
    border-color: var(--accent);
    color: var(--accent);
  }

  .signal-list {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter) 96px;
  }

  .signal-cat {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 14px;
  }
  .signal-cat--consciousness {
    background: rgba(100, 80, 200, 0.18);
    color: #c4b8f0;
    border: 1px solid rgba(150, 120, 220, 0.25);
  }
  .signal-cat--meditation {
    background: rgba(30, 130, 100, 0.18);
    color: #8ddec4;
    border: 1px solid rgba(50, 160, 120, 0.25);
  }
  .signal-cat--wisdom {
    background: rgba(180, 130, 50, 0.18);
    color: #d4a95a;
    border: 1px solid rgba(200, 155, 70, 0.25);
  }
  .hosted-tag {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 3px 9px;
    margin-bottom: 14px;
    margin-left: 6px;
    border-radius: 20px;
    background: rgba(201, 169, 110, 0.14);
    color: var(--accent);
    border: 1px solid rgba(201, 169, 110, 0.4);
  }

  .signal-featured {
    display: grid;
    grid-template-columns: 1fr 64px;
    gap: 24px;
    align-items: start;
    padding: 36px 40px;
    border: 1px solid var(--line-strong);
    border-radius: 6px;
    background: rgba(10, 30, 45, 0.38);
    margin-bottom: 24px;
    transition: border-color 0.25s, background 0.25s;
    color: inherit;
  }
  .signal-featured.with-image {
    grid-template-columns: 280px 1fr;
    padding: 0;
    overflow: hidden;
    gap: 0;
  }
  .signal-featured.with-image .signal-featured-inner {
    padding: 32px 36px;
    align-self: center;
  }
  .signal-featured-image {
    align-self: stretch;
    background: var(--bg-soft);
    overflow: hidden;
    min-height: 220px;
  }
  .signal-featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .signal-featured.with-image:hover .signal-featured-image img { transform: scale(1.03); }
  .signal-featured:hover {
    border-color: var(--accent-deep);
    background: rgba(10, 30, 45, 0.55);
    color: inherit;
  }
  .signal-featured-hed {
    font-family: var(--serif);
    font-size: 30px;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text);
    margin-bottom: 14px;
    letter-spacing: 0.01em;
  }
  .signal-featured-note {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .signal-featured-icon {
    color: var(--accent-deep);
    padding-top: 6px;
    display: flex;
    justify-content: flex-end;
  }

  .signal-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }
  .signal-dot { opacity: 0.4; }

  .signal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .signal-card {
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: rgba(10, 30, 45, 0.28);
    transition: border-color 0.25s, background 0.25s;
    color: inherit;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .signal-card-image {
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--line);
  }
  .signal-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .signal-card:hover .signal-card-image img { transform: scale(1.03); }
  /* Gradient placeholder when no image is set */
  .signal-card-image.cat--consciousness:not(:has(img)) {
    background: linear-gradient(135deg, rgba(100,80,200,0.35) 0%, rgba(40,30,80,0.55) 100%);
  }
  .signal-card-image.cat--meditation:not(:has(img)) {
    background: linear-gradient(135deg, rgba(30,130,100,0.35) 0%, rgba(15,55,40,0.55) 100%);
  }
  .signal-card-image.cat--wisdom:not(:has(img)) {
    background: linear-gradient(135deg, rgba(180,130,50,0.35) 0%, rgba(70,50,20,0.55) 100%);
  }
  .signal-card-image-placeholder {
    font-family: var(--serif);
    font-size: 56px;
    font-weight: 400;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.02em;
  }
  /* Padding moves to the body */
  .signal-card > .signal-cat,
  .signal-card > .hosted-tag,
  .signal-card > .signal-card-hed,
  .signal-card > .signal-card-note,
  .signal-card > .signal-meta {
    margin-left: 26px;
    margin-right: 26px;
  }
  .signal-card > .signal-cat { margin-top: 22px; }
  .signal-card > .signal-meta { margin-bottom: 22px; }
  .signal-card:hover {
    border-color: var(--line-strong);
    background: rgba(10, 30, 45, 0.45);
    color: inherit;
  }
  .signal-card-hed {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--text);
    margin-bottom: 12px;
    letter-spacing: 0.01em;
  }
  .signal-card-note {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .signal-empty {
    text-align: center;
    color: var(--text-faint);
    font-style: italic;
    padding: 48px 0;
  }
  .signal-rss {
    text-align: center;
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  .signal-rss a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .signal-rss a:hover { color: var(--accent); }
  .signal-rss svg { opacity: 0.7; }

  @media (max-width: 900px) {
    .signal-grid { grid-template-columns: repeat(2, 1fr); }
    .signal-hero h1 { font-size: 44px; }
  }
  @media (max-width: 600px) {
    .signal-featured { grid-template-columns: 1fr; padding: 28px 24px; }
    .signal-featured-icon { display: none; }
    .signal-featured-hed { font-size: 24px; }
    .signal-grid { grid-template-columns: 1fr; }
    .signal-hero h1 { font-size: 34px; }
    .signal-hero { padding-top: 56px; }
  }
</style>
