---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const teachers = await getCollection('teachers');
  return teachers.map(teacher => ({
    params: { slug: teacher.slug },
    props: { teacher },
  }));
}

const { teacher } = Astro.props;
const { Content } = await teacher.render();
const tradition = await getEntry(teacher.data.tradition);

// Other teachers in the same tradition (for "More from this tradition" footer)
const allTeachers = await getCollection('teachers');
const siblings = allTeachers
  .filter(t => t.data.tradition.slug === tradition.slug && t.slug !== teacher.slug)
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .slice(0, 4);

// Cross-tradition related teachers (manually-curated `related` field)
const crossRelated = teacher.data.related
  ? (await Promise.all(
      teacher.data.related.map(ref => allTeachers.find(t => t.slug === ref.slug))
    )).filter(Boolean).filter(t => t.data.tradition.slug !== tradition.slug)
  : [];

// Texts attributed to this teacher (best-effort: text frontmatter has an
// optional teacher reference)
const allTexts = await getCollection('texts');
const teacherTexts = allTexts
  .filter(t => t.data.teacher && t.data.teacher.slug === teacher.slug)
  .sort((a, b) => a.data.order - b.data.order);

const videoIds = teacher.data.videos || [];
// "Begin here" featured video: use teacher.data.beginHere if set, else videos[0]
const beginHereId = teacher.data.beginHere || videoIds[0];
const otherVideoIds = videoIds.filter(id => id !== beginHereId);

// Themes this teacher is tagged with (for cross-axis links at the bottom)
const allThemes = await getCollection('themes');
const teacherThemes = (teacher.data.themes || [])
  .map(ref => allThemes.find(t => t.slug === ref.slug))
  .filter(Boolean);
---
<BaseLayout title={teacher.data.name} description={teacher.data.summary} image={teacher.data.image}>

  <div class="breadcrumb">
    <div class="wrapper">
      <a href="/teachers/">Teachers</a>
      <span>/</span>
      <a href={`/traditions/${tradition.slug}/`}>{tradition.data.title}</a>
      <span>/</span>
      {teacher.data.name}
    </div>
  </div>

  <section class="teacher-hero">
    <div class="wrapper">
      <div class="teacher-hero-grid">
        <div class="teacher-hero-portrait">
          {teacher.data.image
            ? <img src={teacher.data.image} alt={teacher.data.name} />
            : <div class="portrait-placeholder" data-initial={teacher.data.name.charAt(0)}></div>}
        </div>
        <div class="teacher-hero-meta">
          <div class="teacher-hero-tradition">
            <a href={`/traditions/${tradition.slug}/`}>{tradition.data.title}</a>
          </div>
          <h1>{teacher.data.name}</h1>
          {(teacher.data.born || teacher.data.died) && (
            <p class="dates">
              {teacher.data.born}{teacher.data.born && teacher.data.died ? ' — ' : ''}{teacher.data.died}
            </p>
          )}
          <p class="summary">{teacher.data.summary}</p>
          {teacher.data.sourceUrl && (
            <p class="source-link">
              <a href={teacher.data.sourceUrl} target="_blank" rel="noopener">Visit official site →</a>
            </p>
          )}
        </div>
      </div>
    </div>
  </section>

  {teacher.data.leadQuote && (
    <section class="lead-quote-section">
      <div class="wrapper">
        <blockquote class="lead-quote">
          <p>{teacher.data.leadQuote.text}</p>
          <footer>
            <span class="attrib">{teacher.data.leadQuote.attribution}</span>
            {teacher.data.leadQuote.source && <span class="src">, {teacher.data.leadQuote.source}</span>}
          </footer>
        </blockquote>
      </div>
    </section>
  )}

  {beginHereId && (
    <section class="begin-here-section">
      <div class="wrapper">
        <div class="begin-here-header">
          <span class="eyebrow">Begin here</span>
          <h2>A first encounter with their voice</h2>
        </div>
        <div class="begin-here-video">
          <VideoEmbed youtubeId={beginHereId} />
        </div>
      </div>
    </section>
  )}

  <section class="teacher-body-section">
    <div class="wrapper">
      <article class="teacher-body prose">
        <Content />
      </article>
    </div>
  </section>

  {otherVideoIds.length > 0 && (
    <section class="teacher-videos">
      <div class="wrapper">
        <div class="section-header">
          <span class="eyebrow">In their voice</span>
          <h2>{otherVideoIds.length === 1 ? 'Another talk' : 'More talks'}</h2>
        </div>
        <div class={`videos-grid ${otherVideoIds.length === 1 ? 'single' : ''}`}>
          {otherVideoIds.map(id => <VideoEmbed youtubeId={id} />)}
        </div>
      </div>
    </section>
  )}

  {teacherTexts.length > 0 && (
    <section class="teacher-texts">
      <div class="wrapper">
        <div class="section-header">
          <span class="eyebrow">In the library</span>
          <h2>Texts in their lineage</h2>
        </div>
        <div class="text-links">
          {teacherTexts.map(t => (
            <a href={`/texts/${t.slug}/`} class="text-link-card">
              <div class="text-link-title">{t.data.title}</div>
              <div class="text-link-blurb">{t.data.description.split('.')[0]}.</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {teacherThemes.length > 0 && (
    <section class="teacher-themes-section">
      <div class="wrapper">
        <div class="section-header">
          <span class="eyebrow">Threads through their teaching</span>
          <h2>Related themes</h2>
        </div>
        <div class="theme-pills">
          {teacherThemes.map(t => (
            <a href={`/themes/${t.slug}/`} class="theme-pill">
              <span class="theme-pill-title">{t.data.title}</span>
              <span class="theme-pill-sub">{t.data.subtitle.split('.')[0]}.</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {crossRelated.length > 0 && (
    <section class="teacher-siblings">
      <div class="wrapper">
        <div class="section-header">
          <span class="eyebrow">Across traditions</span>
          <h2>Other voices in conversation with theirs</h2>
        </div>
        <div class="siblings-grid">
          {crossRelated.map(s => (
            <a href={`/teachers/${s.slug}/`} class="sibling-card">
              <div class="sibling-portrait">
                {s.data.image && <img src={s.data.image} alt={s.data.name} />}
              </div>
              <div class="sibling-name">{s.data.name}</div>
              <div class="sibling-dates">{s.data.born && s.data.died ? `${s.data.born} — ${s.data.died}` : (s.data.born || s.data.died || '')}</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {siblings.length > 0 && (
    <section class="teacher-siblings">
      <div class="wrapper">
        <div class="section-header">
          <span class="eyebrow">From the same lineage</span>
          <h2>Other teachers in {tradition.data.title}</h2>
        </div>
        <div class="siblings-grid">
          {siblings.map(s => (
            <a href={`/teachers/${s.slug}/`} class="sibling-card">
              <div class="sibling-portrait">
                {s.data.image && <img src={s.data.image} alt={s.data.name} />}
              </div>
              <div class="sibling-name">{s.data.name}</div>
              <div class="sibling-dates">
                {s.data.born && s.data.died ? `${s.data.born} — ${s.data.died}` : (s.data.born || s.data.died || '')}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .breadcrumb { padding: 32px 0 0; font-size: 13px; letter-spacing: 0.06em; color: var(--text-faint); }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb span { margin: 0 12px; color: var(--text-faint); }

  .teacher-hero { padding: 48px 0 0; }
  .teacher-hero-grid { display: grid; grid-template-columns: 320px 1fr; gap: 64px; align-items: center; }
  .teacher-hero-portrait { width: 320px; height: 320px; border-radius: 50%; overflow: hidden; border: 1px solid var(--line); background: var(--bg-soft); }
  .teacher-hero-portrait img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .portrait-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 120px; font-weight: 300; color: var(--text-faint); }
  .portrait-placeholder::after { content: attr(data-initial); }
  .teacher-hero-tradition { font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 18px; font-weight: 500; }
  .teacher-hero-tradition a { color: inherit; }
  .teacher-hero-tradition a:hover { color: var(--text); }
  .teacher-hero h1 { font-size: 64px; font-weight: 400; line-height: 1; letter-spacing: -0.02em; margin: 0 0 12px; }
  .dates { font-family: var(--sans); font-size: 13px; letter-spacing: 0.12em; color: var(--text-faint); margin-bottom: 28px; }
  .summary { font-family: var(--serif); font-size: 22px; font-style: italic; color: var(--text-muted); line-height: 1.55; max-width: 640px; font-weight: 300; }
  .source-link { margin-top: 28px; font-family: var(--sans); font-size: 14px; }
  .source-link a { color: var(--accent); border-bottom: 1px solid rgba(201,169,97,0.4); padding-bottom: 1px; }
  .source-link a:hover { color: var(--text); border-bottom-color: var(--accent); }

  .lead-quote-section { padding: 64px 0 0; }
  .lead-quote { max-width: 780px; margin: 0 auto; text-align: center; padding: 0 var(--gutter); border: none; }
  .lead-quote p { font-family: var(--serif); font-size: 26px; font-style: italic; line-height: 1.45; color: var(--text); font-weight: 300; margin-bottom: 20px; }
  .lead-quote footer { font-family: var(--sans); font-size: 13px; letter-spacing: 0.08em; color: var(--accent); }
  .lead-quote .src { color: var(--text-faint); }

  .begin-here-section { padding: 80px 0 0; }
  .begin-here-header { margin-bottom: 32px; }
  .begin-here-header .eyebrow { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); font-weight: 500; }
  .begin-here-header h2 { font-family: var(--serif); font-size: 32px; font-weight: 400; color: var(--text); margin-top: 12px; }
  .begin-here-video { max-width: 980px; }

  .teacher-themes-section { padding: 96px 0 0; }
  .theme-pills { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
  .theme-pill { display: flex; flex-direction: column; gap: 6px; padding: 20px 24px; border: 1px solid var(--line); color: inherit; transition: border-color 0.3s; }
  .theme-pill:hover { border-color: var(--accent); color: inherit; }
  .theme-pill-title { font-family: var(--serif); font-size: 20px; font-weight: 500; color: var(--text); }
  .theme-pill-sub { font-size: 13px; color: var(--text-muted); line-height: 1.5; font-weight: 300; }

  .teacher-body-section { padding: 80px 0 0; }
  .teacher-body { max-width: 780px; margin: 0 auto; font-family: var(--serif); font-size: 21px; line-height: 1.7; color: var(--text); font-weight: 300; }
  .teacher-body :global(p) { margin-bottom: 22px; }
  .teacher-body :global(p:first-child::first-letter) { font-size: 64px; float: left; line-height: 0.85; margin: 8px 12px 0 0; color: var(--accent); font-weight: 500; }
  .teacher-body :global(h2) { font-family: var(--sans); font-size: 13px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); font-weight: 500; margin: 48px 0 18px; }
  .teacher-body :global(h3) { font-family: var(--serif); font-size: 26px; margin: 32px 0 12px; color: var(--text); font-weight: 500; }
  .teacher-body :global(a) { color: var(--accent); border-bottom: 1px solid rgba(201,169,97,0.4); padding-bottom: 1px; }
  .teacher-body :global(a:hover) { color: var(--text); border-bottom-color: var(--accent); }
  .teacher-body :global(ul) { padding-left: 0; list-style: none; }
  .teacher-body :global(ul li) { padding: 10px 0; border-bottom: 1px solid var(--line); margin-bottom: 0; }
  .teacher-body :global(ul li:last-child) { border-bottom: none; }
  .teacher-body :global(em) { color: var(--text-muted); }
  .teacher-body :global(blockquote) {
    margin: 28px 0;
    padding: 8px 0 8px 28px;
    border-left: 2px solid var(--accent);
    font-family: var(--serif);
    font-size: 20px;
    line-height: 1.5;
    color: var(--text);
    font-weight: 300;
    font-style: italic;
  }
  .teacher-body :global(blockquote p) {
    margin-bottom: 12px;
  }
  .teacher-body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .teacher-videos { padding: 96px 0 0; }
  .teacher-videos .wrapper { max-width: 980px; }
  .videos-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 32px; }
  .videos-grid.single { grid-template-columns: minmax(0, 780px); justify-content: center; }

  .teacher-texts { padding: 96px 0 0; }
  .text-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; }
  .text-link-card { display: block; padding: 28px; border: 1px solid var(--line); transition: border-color 0.3s; color: inherit; }
  .text-link-card:hover { border-color: var(--accent); color: inherit; }
  .text-link-title { font-family: var(--serif); font-size: 22px; color: var(--text); font-weight: 500; margin-bottom: 8px; }
  .text-link-blurb { font-size: 14px; color: var(--text-muted); line-height: 1.6; font-weight: 300; }

  .teacher-siblings { padding: 96px 0; margin-top: 64px; border-top: 1px solid var(--line); }
  .siblings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px; }
  .sibling-card { text-align: center; color: inherit; display: block; }
  .sibling-portrait { width: 140px; height: 140px; border-radius: 50%; overflow: hidden; margin: 0 auto 14px; background: var(--bg-soft); border: 1px solid var(--line); transition: border-color 0.3s; }
  .sibling-portrait img { width: 100%; height: 100%; object-fit: cover; }
  .sibling-card:hover .sibling-portrait { border-color: var(--accent-deep); }
  .sibling-name { font-family: var(--serif); font-size: 18px; font-weight: 500; color: var(--text); margin-bottom: 4px; }
  .sibling-dates { font-size: 11px; letter-spacing: 0.06em; color: var(--text-faint); }

  .section-header { margin-bottom: 40px; }
  .section-header .eyebrow { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); font-weight: 500; }
  .section-header h2 { font-family: var(--serif); font-size: 36px; font-weight: 400; color: var(--text); margin-top: 12px; }

  @media (max-width: 800px) {
    .teacher-hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .teacher-hero-portrait { width: 200px; height: 200px; margin: 0 auto; }
    .teacher-hero h1 { font-size: 44px; text-align: center; }
    .dates, .summary, .source-link { text-align: center; }
    .teacher-hero-tradition { text-align: center; }
  }
</style>
