---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoCard from '../components/VideoCard.astro';
import { videos, channelUrl } from '../data/videos';
---
<BaseLayout
  title="Watch"
  description="Curated video teachings from the Soul Spirit Self YouTube library. Teachers, satsangs, and contemplative talks from across the nondual traditions."
>

  <section class="watch-hero">
    <span class="eyebrow">The library</span>
    <h1>Watch</h1>
    <p class="lede">
      A growing library of curated teachings from across the nondual traditions. Click any thumbnail to open the full video on the Soul Spirit Self YouTube channel.
    </p>
    <div class="rule-gold-h"></div>
  </section>

  <section class="watch-grid-section">
    <div class="videos-grid">
      {videos.map(v => (
        <VideoCard youtubeId={v.id} title={v.title} caption={v.caption} />
      ))}
    </div>
    <div class="channel-link">
      <a href={channelUrl} target="_blank" rel="noopener" class="btn primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.4 3.5 12 3.5 12 3.5s-7.4 0-9.4.6A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c2 .6 9.4.6 9.4.6s7.4 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg>
        Visit the YouTube channel
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .watch-hero {
    text-align: center;
    padding: 96px var(--gutter) 48px;
    max-width: 760px;
    margin: 0 auto;
  }
  .watch-hero h1 {
    font-family: var(--serif);
    font-size: 84px;
    font-weight: 400;
    letter-spacing: 0.04em;
    margin: 12px 0 24px;
  }
  .watch-hero .lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .watch-grid-section {
    padding: 32px var(--gutter) 96px;
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px 28px;
  }
  .channel-link { text-align: center; margin-top: 80px; }

  @media (max-width: 900px) { .videos-grid { grid-template-columns: repeat(2, 1fr); } .watch-hero h1 { font-size: 56px; } }
  @media (max-width: 600px) { .videos-grid { grid-template-columns: 1fr; } }
</style>
