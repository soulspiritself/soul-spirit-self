---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoCard from '../components/VideoCard.astro';
import DailyContemplation from '../components/DailyContemplation.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { getCollection } from 'astro:content';
import { featuredVideos, channelUrl } from '../data/videos';

const traditions = (await getCollection('traditions')).sort((a, b) => a.data.order - b.data.order);
const homeFeatured = featuredVideos.slice(0, 6);

const dailyQuote = {
  quote: 'To be here, fully here, in this timeless moment, is the ultimate freedom.',
  author: 'Mooji',
  source: 'Dawn Rising',
};
---
<BaseLayout
  title="Soul Spirit Self"
  description="An open library of nondual wisdom across contemplative traditions. Foundational texts, teaching, lineage."
>

  <!-- HERO -->
  <section class="home-hero">
    <div class="brand-orb">
      <img src="/images/soul-spirit-self-logo.png" alt="" />
    </div>
    <h1 class="display home-title">Soul Spirit Self</h1>
    <p class="tagline-italic home-tagline">A Journey Within</p>
    <div class="rule-gold"></div>
    <p class="home-blurb">
      Welcome to <strong>Soul Spirit Self</strong>. An open library of nondual wisdom across the contemplative traditions, drawing on foundational texts, the lineages that carry them, and the recordings of those still speaking the recognition out loud.
    </p>

    <div class="hero-cta">
      <a href={channelUrl} target="_blank" rel="noopener" class="btn primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.4 3.5 12 3.5 12 3.5s-7.4 0-9.4.6A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c2 .6 9.4.6 9.4.6s7.4 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg>
        Watch now
      </a>
      <a href="/traditions/" class="btn">Explore the library</a>
    </div>
    <p class="hero-sub">New content coming soon</p>
  </section>

  <!-- FEATURED VIDEOS -->
  <section class="section featured-videos">
    <div class="section-header centered">
      <span class="eyebrow">Featured</span>
      <h2>Living teaching, on screen</h2>
    </div>
    <div class="videos-grid">
      {homeFeatured.map(v => (
        <VideoCard youtubeId={v.id} title={v.title} caption={v.caption} />
      ))}
    </div>
    <div class="more-link">
      <a href="/watch/" class="btn">See the full library</a>
    </div>
  </section>

  <!-- TRADITIONS LIBRARY -->
  <section class="section traditions-section">
    <div class="section-header centered">
      <span class="eyebrow">The library</span>
      <h2>Traditions of nondual recognition</h2>
      <p class="section-lede">
        Each tradition is a distinct articulation of one recognition. Different vocabulary, different rituals, different lineages, the same pointing.
      </p>
    </div>
    <div class="traditions-grid">
      {traditions.map(t => (
        <a href={`/traditions/${t.slug}/`} class="trad-card">
          <h3>{t.data.title}</h3>
          <p>{t.data.subtitle}</p>
          <span class="trad-link">Enter →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- DAILY CONTEMPLATION -->
  <DailyContemplation quote={dailyQuote.quote} author={dailyQuote.author} source={dailyQuote.source} />

  <!-- EMAIL SIGNUP -->
  <EmailSignup />

</BaseLayout>

<style>
  /* Hero */
  .home-hero {
    text-align: center;
    padding: 96px var(--gutter) 64px;
    max-width: 820px;
    margin: 0 auto;
  }
  .brand-orb {
    width: 144px;
    height: 144px;
    margin: 0 auto 40px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.35);
  }
  .brand-orb img { width: 100%; height: 100%; display: block; }
  .home-title {
    font-size: 64px;
    color: var(--text);
    margin: 0 0 22px;
    line-height: 1.05;
  }
  .home-tagline {
    font-size: 28px;
    margin-bottom: 0;
    line-height: 1.4;
  }
  .home-blurb {
    font-family: var(--serif);
    font-size: 19px;
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 580px;
    margin: 32px auto 40px;
  }
  .home-blurb strong { color: var(--text); font-weight: 500; }
  .hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .hero-sub {
    margin-top: 22px;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* Section header centered variant */
  .section-header.centered { text-align: center; max-width: 760px; margin: 0 auto 56px; }
  .section-header h2 {
    font-family: var(--serif);
    font-size: 44px;
    font-weight: 400;
    margin-top: 12px;
    letter-spacing: 0.01em;
  }
  .section-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--text-muted);
    margin-top: 16px;
    line-height: 1.6;
  }

  /* Videos grid */
  .featured-videos { padding-top: 32px; padding-bottom: 32px; }
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .more-link { text-align: center; margin-top: 56px; }
  @media (max-width: 900px) { .videos-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .videos-grid { grid-template-columns: 1fr; } }

  /* Traditions */
  .traditions-section { padding-top: 32px; padding-bottom: 32px; }
  .traditions-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
  .trad-card {
    padding: 36px 32px;
    border: 1px solid var(--line);
    background: rgba(10, 30, 45, 0.32);
    transition: all 0.3s;
    color: inherit;
    display: block;
    border-radius: 4px;
  }
  .trad-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    background: rgba(10, 30, 45, 0.48);
    color: inherit;
  }
  .trad-card h3 {
    font-family: var(--serif);
    font-size: 28px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 12px;
  }
  .trad-card p {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .trad-link {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 700px) {
    .home-title { font-size: 44px; letter-spacing: 0.14em; }
    .home-tagline { font-size: 24px; }
    .brand-orb { width: 112px; height: 112px; }
  }
</style>
