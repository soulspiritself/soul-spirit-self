---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="This page does not exist.">
  <section class="notfound">
    <span class="eyebrow">404</span>
    <h1>Nothing is here</h1>
    <p>The page you were looking for does not exist, or has moved. Which is, perhaps, its own small teaching.</p>
    <div class="notfound-links">
      <a class="btn primary" href="/">Return home</a>
      <a class="btn" href="/texts/">Browse the texts</a>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    padding: 120px var(--gutter) 80px;
  }
  .notfound .eyebrow {
    display: block;
    margin-bottom: 16px;
  }
  .notfound h1 {
    font-family: var(--serif);
    font-size: 48px;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 16px;
  }
  .notfound p {
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .notfound-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
