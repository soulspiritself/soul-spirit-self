# Soul Spirit Self - Environment Variables
# Copy this file to .env and fill in your values
# .env is git-ignored and never committed

# Google AI Studio API key for Imagen 4 image generation
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-api-key-here

# Optional: alternate location for the .env if you keep it outside the project
# (defaults to ~/Documents/Claude/.env per the user's existing setup)
# IMAGEN_ENV_PATH=~/Documents/Claude/.env
